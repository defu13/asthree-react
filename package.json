    "@react-three/postprocessing": ">=2",
    "postprocessing": ">=6.36.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "three": "^0.176.0",
    "@react-three/fiber": "^8.0.0",
    "@react-three/drei": "^9.0.0",
    "@react-three/postprocessing": "^2.0.0",
    "postprocessing": "^6.36.0"
